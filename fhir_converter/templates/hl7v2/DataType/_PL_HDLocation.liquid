{% if HD -%}
    {% if HD."1" -%}
        "name":"{{ HD."1" }}",
    {% else -%}
        "name":"{{ HD.Value }}",
    {% endif -%}
    {% if HD."2" and HD."3" -%}
    "identifier":
    [
        {
            {% if HD."3" == "ISO" or HD."3" == "CLIA" or HD."3" == "CLIP" -%}
                "value":"urn:oid:{{ HD."2" }}",
            {% elsif HD."3" == "UUID" or HD."3" == "GUID"-%}
                "value":"urn:uuid:{{ HD."2" }}",
            {% else %}
                "value":"{{ HD."2" }}",
            {% endif -%}
            
            {% if HD."3" == "ISO" or HD."3" == "CLIA" or HD."3" == "CLIP" or HD."3" == "UUID" or HD."3" == "GUID"-%}
                "system": "urn:ietf:rfc:3986",
            {% else %}
                "system": "http://example.com/v2-to-fhir-converter/Identifier/{{HD."3"}}",
            {% endif -%}
        },
    ],
    {% endif -%}
{% endif -%}
